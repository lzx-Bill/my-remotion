#!/usr/bin/env sh
# Pre-commit hook for my-remotion
# Enforce: no big binaries, no temp files, no out/ staging.
# Skip with: git commit --no-verify (only when you know what you're doing)
#
# Enable in this repo (one-time):
#   git config core.hooksPath .githooks

set -e

# 1. Block staging of out/ contents (should be gitignored, but defense in depth)
STAGED_OUT=$(git diff --cached --name-only -- 'out/' 2>/dev/null | head -1)
if [ -n "$STAGED_OUT" ]; then
  echo "pre-commit: ERROR — attempting to commit out/ contents: $STAGED_OUT"
  echo "  out/ is .gitignored. If you really need it, git commit --no-verify."
  exit 1
fi

# 2. Block staging of root-level matrix-media-*.png (MCP temp downloads)
STAGED_MATRIX=$(git diff --cached --name-only -- 'matrix-media-*.png' 2>/dev/null | head -1)
if [ -n "$STAGED_MATRIX" ]; then
  echo "pre-commit: ERROR — attempting to commit root-level matrix-media-*.png: $STAGED_MATRIX"
  echo "  These are MCP temp files. Move or trash them before commit."
  exit 1
fi

# 3. Block large blobs (>10 MB) — including binary files (numstat shows - - for binary)
# Iterate staged entries and check blob size directly.
LARGE_PATHS=$(git diff --cached --name-only --diff-filter=ACMR | while read -r f; do
  case "$f" in
    "") continue ;;
  esac
  HASH=$(git ls-files --stage -- "$f" | awk 'NR==1{print $2}')
  [ -z "$HASH" ] && continue
  SIZE=$(git cat-file -s "$HASH" 2>/dev/null || echo 0)
  if [ "$SIZE" -gt 10485760 ]; then
    printf '%s\t%s bytes\n' "$f" "$SIZE"
  fi
done)
if [ -n "$LARGE_PATHS" ]; then
  echo "pre-commit: ERROR — large file in staging (>10 MB):"
  echo "$LARGE_PATHS"
  echo "  Render artifacts belong in out/ (gitignored) or E:\\Mavis-output\\<project>/"
  echo "  Skip with: git commit --no-verify"
  exit 1
fi

# 4. Friendly reminder if clean-output.py finds stale items (does NOT block)
if command -v python >/dev/null 2>&1; then
  if [ -f scripts/common/clean-output.py ]; then
    REMINDER=$(python scripts/common/clean-output.py 2>&1 || true)
    if echo "$REMINDER" | grep -qE 'Plan: [1-9]'; then
      echo "pre-commit: clean-output.py found stale items. Consider running:"
      echo "  python scripts/common/clean-output.py --apply"
      # Don't block; just warn.
    fi
  fi
fi

exit 0

